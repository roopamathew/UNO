generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoomStatus {
  WAITING
  STARTING
  IN_PROGRESS
  FINISHED
}

enum MessageType {
  USER
  SYSTEM
  GAME
}

enum GameStatus {
  IN_PROGRESS
  COMPLETED
  ABANDONED
}

enum AuthProvider {
  LOCAL
  GOOGLE
}

model User {
  id            String       @id @default(cuid())
  email         String       @unique
  username      String       @unique
  passwordHash  String?
  avatarUrl     String?
  avatarColor   String       @default("#3B82F6")
  authProvider  AuthProvider @default(LOCAL)
  googleId      String?      @unique
  emailVerified Boolean      @default(false)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  settings          UserSettings?
  stats             UserStats?
  refreshTokens     RefreshToken[]
  passwordResets    PasswordReset[]
  hostedRooms       Room[]           @relation("RoomHost")
  roomPlayers       RoomPlayer[]
  gamePlayers       GamePlayer[]
  moves             Move[]
  chatMessages      Message[]
  achievements      UserAchievement[]
  voiceSessions     VoiceSession[]

  @@index([email])
  @@index([username])
}

model UserSettings {
  id                    String  @id @default(cuid())
  userId                String  @unique
  theme                 String  @default("dark")
  animationsEnabled     Boolean @default(true)
  soundEnabled          Boolean @default(true)
  musicEnabled          Boolean @default(true)
  voiceVolume           Float   @default(0.8)
  language              String  @default("en")
  notificationsEnabled  Boolean @default(true)
  reducedMotion         Boolean @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserStats {
  id               String @id @default(cuid())
  userId           String @unique
  wins             Int    @default(0)
  losses           Int    @default(0)
  gamesPlayed      Int    @default(0)
  totalPoints      Int    @default(0)
  longestWinStreak Int    @default(0)
  currentWinStreak Int    @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model PasswordReset {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
}

model Room {
  id               String     @id @default(cuid())
  code             String     @unique
  hostId           String
  status           RoomStatus @default(WAITING)
  name             String     @default("UNO Room")
  isPrivate        Boolean    @default(false)
  maxPlayers       Int        @default(4)
  allowSpectators  Boolean    @default(false)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  host       User         @relation("RoomHost", fields: [hostId], references: [id])
  players    RoomPlayer[]
  houseRules HouseRules?
  messages   Message[]
  games      Game[]
  voiceSessions VoiceSession[]

  @@index([code])
  @@index([hostId])
  @@index([status])
}

model RoomPlayer {
  id          String   @id @default(cuid())
  roomId      String
  userId      String?
  guestName   String?
  avatarUrl   String?
  avatarColor String   @default("#3B82F6")
  isHost      Boolean  @default(false)
  isReady     Boolean  @default(false)
  isConnected Boolean  @default(true)
  ping        Int      @default(0)
  socketId    String?
  joinedAt    DateTime @default(now())

  room Room  @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([roomId, userId])
  @@index([roomId])
  @@index([userId])
}

model HouseRules {
  id                   String @id @default(cuid())
  roomId               String @unique
  stackDrawTwo         Boolean @default(false)
  stackWildDrawFour    Boolean @default(false)
  jumpIn               Boolean @default(false)
  sevenO               Boolean @default(false)
  forcePlay            Boolean @default(false)
  drawUntilPlayable    Boolean @default(false)
  customScoreLimit     Int     @default(0)
  winningScore         Int     @default(500)
  numberOfDecks        Int     @default(1)
  turnTimerSeconds     Int     @default(30)
  customRules          Json    @default("[]")

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)
}

model Game {
  id          String     @id @default(cuid())
  roomId      String
  status      GameStatus @default(IN_PROGRESS)
  winnerId    String?
  startedAt   DateTime   @default(now())
  endedAt     DateTime?
  gameState   Json?

  room    Room         @relation(fields: [roomId], references: [id])
  players GamePlayer[]
  moves   Move[]

  @@index([roomId])
  @@index([status])
}

model GamePlayer {
  id       String  @id @default(cuid())
  gameId   String
  userId   String?
  username String
  score    Int     @default(0)
  rank     Int?
  isWinner Boolean @default(false)

  game Game  @relation(fields: [gameId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([gameId])
  @@index([userId])
}

model Move {
  id        String   @id @default(cuid())
  gameId    String
  userId    String?
  moveType  String
  moveData  Json
  turnNumber Int
  createdAt DateTime @default(now())

  game Game  @relation(fields: [gameId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([gameId])
}

model Message {
  id        String      @id @default(cuid())
  roomId    String
  senderId  String?
  senderName String
  content   String
  type      MessageType @default(USER)
  createdAt DateTime    @default(now())

  room   Room  @relation(fields: [roomId], references: [id], onDelete: Cascade)
  sender User? @relation(fields: [senderId], references: [id], onDelete: SetNull)

  @@index([roomId])
  @@index([createdAt])
}

model VoiceSession {
  id        String   @id @default(cuid())
  roomId    String
  userId    String
  joinedAt  DateTime @default(now())
  leftAt    DateTime?

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([roomId])
}

model Achievement {
  id          String @id @default(cuid())
  code        String @unique
  name        String
  description String
  icon        String

  users UserAchievement[]
}

model UserAchievement {
  id            String   @id @default(cuid())
  userId        String
  achievementId String
  unlockedAt    DateTime @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
}
